# PostgreSQL 数据库配置
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_secure_password
DB_HOST=your_database_host
DB_PORT=5432

# Redis 缓存配置（多个应用可共享同一 Redis 实例，通过不同 DB 编号隔离）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=            # 可选，如果 Redis 设置了密码
REDIS_DB=0                 # 每个应用使用不同的 DB 编号（0-15），实现数据隔离
CACHE_TTL=3600             # 缓存过期时间（秒），默认 1 小时

# Docker Compose 配置
COMPOSE_PROJECT_NAME=rival-map
